# Alcove runtime environment template.
#
# When installed on a Reachy Mini, copy this file to `runtime.env` (same folder)
# and fill in your keys. The Alcove app reads this file at startup.
#
# The OpenAI key can also be entered via Pollen Desktop's "Required" badge
# on first run — but shipping it in runtime.env avoids that step.

# ─── OpenAI (required) ───────────────────────────────────────
OPENAI_API_KEY=

# The Realtime model to use. Default works for both marin and coral voices.
MODEL_NAME="gpt-realtime"

# ─── Tavily (optional — required for the web_search tool) ────
# Get a free key at https://tavily.com
TAVILY_API_KEY=

# ─── Reachy Mini profile ─────────────────────────────────────
# Which profile Alcove starts on. Persona A / Persona B are the framework
# defaults; rename them once you customize your two personas.
REACHY_MINI_CUSTOM_PROFILE="persona_a"

# ─── Time-of-day awareness (optional) ────────────────────────
# Alcove injects a "CURRENT CONTEXT" preamble into each session's prompt
# so your personas can attune tone and pacing to the hour (morning,
# midday, evening, night). Set this to your IANA timezone name so the
# hour matches where the user actually is; if unset, the system's local
# time is used.
# ALCOVE_TIMEZONE="America/Denver"
# ALCOVE_TIMEZONE="Europe/Paris"
# ALCOVE_TIMEZONE="Asia/Tokyo"

# ─── Local vision (optional) ─────────────────────────────────
# Only needed if you launch with --local-vision. Default is to use
# OpenAI Realtime's built-in vision through the camera tool.
# LOCAL_VISION_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct
# HF_HOME=./cache
# HF_TOKEN=
